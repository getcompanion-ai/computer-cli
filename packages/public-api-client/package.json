{
  "name": "@microagentcomputer/public-api-client",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../../apps/api/openapi.json -o src/generated/schema.ts",
    "build": "pnpm run generate && tsc -p tsconfig.build.json",
    "typecheck": "pnpm run generate && tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
